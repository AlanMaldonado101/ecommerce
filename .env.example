# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Mercado Pago Configuration
# For testing, use: TEST-18294faa-6945-4f1e-ab29-4647f2c4d5df
# For production, get your key from: https://www.mercadopago.cl/developers
VITE_MERCADOPAGO_PUBLIC_KEY=your_mercadopago_public_key

# Note: The following variables are configured in Supabase Edge Functions Secrets
# They should NOT be added to this .env file
# 
# MERCADOPAGO_ACCESS_TOKEN - Configure in Supabase Dashboard → Edge Functions → Secrets
# FRONTEND_URL - Configure in Supabase Dashboard → Edge Functions → Secrets
#
# See MERCADOPAGO_SETUP.md for detailed setup instructions
